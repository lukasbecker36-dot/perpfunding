# Optional API keys — copy to .env and fill in if needed

# KuCoin futures API (only required for private endpoints)
# KUCOIN_API_KEY=
# KUCOIN_API_SECRET=
# KUCOIN_API_PASSPHRASE=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# SQLite database path (default: out/history.sqlite)
# DB_PATH=out/history.sqlite
